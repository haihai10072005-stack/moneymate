# ===== MoneyMate — biến môi trường =====
# Copy thành .env rồi điền giá trị thật.

# --- AI (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Server ---
PORT=8123

# --- Lưu trữ ---
# Để TRỐNG => dùng db.json (local). Điền connection string Postgres để chạy production
# (Neon/Supabase/Railway... đều có free tier). VD: postgres://user:pass@host:5432/dbname
DATABASE_URL=
# Đặt 'disable' nếu Postgres local không dùng SSL (mặc định bật SSL cho hosted)
PGSSL=

# --- Casso (Open Banking) ---
CASSO_WEBHOOK_TOKEN=

# --- VNPAY (sandbox) — đăng ký free tại https://sandbox.vnpayment.vn ---
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Đổi thành domain thật khi deploy, vd https://moneymate.onrender.com/api/vnpay/return
VNP_RETURN_URL=
